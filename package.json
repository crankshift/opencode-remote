{
  "name": "@crankshift/opencode-remote",
  "description": "A messenger-based chat interface for OpenCode, starting with Telegram.",
  "version": "0.3.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crankshift/opencode-remote.git"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "README.md",
    "FEATURES.md",
    "CHANGELOG.md",
    "TODO.md",
    "LICENSE"
  ],
  "bin": {
    "opencode-remote": "dist/bin/opencode-remote.mjs"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "setup": "node src/bin/opencode-remote.js setup",
    "start": "node src/bin/opencode-remote.js run",
    "dev": "node --watch src/bin/opencode-remote.js run --state-suffix dev",
    "build": "tsdown",
    "prepack": "pnpm run build",
    "smoke:package": "pnpm run build && node tests/smoke/packageSmoke.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "check": "pnpm run lint && pnpm test && pnpm run smoke:package"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.15.10",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "grammy": "^1.43.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "publint": "^0.3.21",
    "tsdown": "^0.22.0",
    "vitest": "^4.1.7"
  }
}
